# App
APP_NAME=App Backend
DEBUG=false
API_PREFIX=/api/v1

# MongoDB
MONGODB_URL=mongodb://admin:admin_secret@mongodb:27017/maindb?authSource=admin
MONGODB_DB=maindb

# Redis
REDIS_URL=redis://:admin_secret@redis:6379/0

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=app
KEYCLOAK_CLIENT_ID=app-api

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email
RESEND_API_KEY=re_...

# Sentry
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
